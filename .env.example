# Copia este archivo a .env (no subir .env al repositorio)
# Valores ejemplo — reemplaza antes de desplegar en producción
SECRET_KEY=replace-with-a-long-random-secret
DEMO_USERNAME=admin
DEMO_PASSWORD=secret
DEMO_ROLES=RH_ADMIN,PAYROLL_USER
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=60
SMMLV=1300000
AUXILIO_TRANSPORTE=140000

# Desarrollo local sin PostgreSQL
# Recomendada: ruta relativa al repo que siempre apunta al mismo fichero
DATABASE_URL=sqlite:///./backend/nominapro.db
SECRET_KEY=NominaPro-demo-jwt-secret-2026-use-env-in-production
DEMO_USERNAME=admin
DEMO_PASSWORD=secret
DEMO_ROLES=RH_ADMIN,PAYROLL_USER
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Producción / si usas PostgreSQL local (descomentar y ajustar):
# PORT=3000
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nominapro

#NODE_ENV=development